APP_NAME=Sicode
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_QA=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default Database Config
DB_CONNECTION=mysql
DB_HOST=sicode-legacy-mariadb
DB_PORT=3306
DB_DATABASE=sicode_legacy
DB_USERNAME=sicode_legacy
DB_PASSWORD=legacy_dev_password

CORE_LAUNCH_EXCHANGE_URL=http://sicode-core:8000/api/core/launch/exchange
CORE_LAUNCH_CLIENT_IDENTIFIER=sicode-legacy-local
CORE_LAUNCH_CLIENT_SECRET=local_legacy_core_secret
CORE_LAUNCH_ISSUER=sicode-core
CORE_LAUNCH_APPLICATION=sicode-legacy
CORE_LAUNCH_CONTEXT=ES

# Config Origin database information
DB1_CONNECTION=sqlsrv1
DB1_HOST=
DB1_PORT=
DB1_DATABASE=
DB1_USERNAME=
DB1_PASSWORD=

# Sicode Log SQL
# DB2_CONNECTION=
# DB2_HOST=
# DB2_PORT=
# DB2_DATABASE=
# DB2_USERNAME=
# DB2_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
QUEUE_HIGH_CONNECTION=database
QUEUE_HIGH=high
QUEUE_EXPORTS_CONNECTION=database
QUEUE_EXPORTS=exports
QUEUE_MESSAGES_CONNECTION=database
QUEUE_MESSAGES=messages
QUEUE_DEFAULT_CONNECTION=database
QUEUE_DEFAULT=default
QUEUE_NOTIFICATIONS_CONNECTION=database
QUEUE_NOTIFICATIONS=messages
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=localhost
PUSHER_PORT=8080
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

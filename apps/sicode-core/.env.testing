APP_NAME="SICODE CORE"
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost

HASH_DRIVER=argon2id
HASH_VERIFY=true
ARGON_MEMORY=65536
ARGON_TIME=3
ARGON_THREADS=1

DB_CONNECTION=pgsql
DB_HOST=sicode-postgres
DB_PORT=5432
DB_DATABASE=sicode_core
DB_USERNAME=sicode_core
DB_PASSWORD=local_dev_password

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

CORE_LAUNCH_ISSUER=sicode-core
CORE_LAUNCH_TTL_SECONDS=300
CORE_LAUNCH_CLIENT_SECRETS={}
